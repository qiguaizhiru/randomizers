{
  "name": "genshin-character-randomizer",
  "version": "1.0.0",
  "description": "原神角色随机抽取器",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable"
  },
  "build": {
    "appId": "com.genshin.randomizer",
    "productName": "原神角色随机抽取器",
    "win": { "target": "portable", "icon": null },
    "files": ["main.js", "index.html", "genshin_data.js"],
    "portable": { "artifactName": "原神角色随机抽取器.exe" }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  }
}
