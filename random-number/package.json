{
  "name": "random-number-generator",
  "version": "1.0.0",
  "description": "随机数生成器",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable"
  },
  "build": {
    "appId": "com.random.number",
    "productName": "随机数生成器",
    "win": {
      "target": "portable",
      "icon": null
    },
    "files": [
      "main.js",
      "index.html"
    ],
    "portable": {
      "artifactName": "随机数生成器.exe"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  }
}
