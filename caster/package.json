{
  "name": "caster-randomizer",
  "version": "1.0.0",
  "description": "解说主持随机抽取器",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable"
  },
  "build": {
    "appId": "com.caster.randomizer",
    "productName": "解说主持随机抽取器",
    "win": {
      "target": "portable",
      "icon": null
    },
    "files": [
      "main.js",
      "index.html"
    ],
    "portable": {
      "artifactName": "解说主持随机抽取器.exe"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  }
}
