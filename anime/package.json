{
  "name": "anime-random-picker",
  "version": "1.0.0",
  "description": "随机动漫抽取器",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable"
  },
  "build": {
    "appId": "com.anime.picker",
    "productName": "随机动漫抽取器",
    "win": {
      "target": "portable",
      "icon": null
    },
    "portable": {
      "artifactName": "随机动漫抽取器.exe"
    },
    "files": [
      "main.js",
      "index.html",
      "anime_data.js"
    ],
    "directories": {
      "output": "dist"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  }
}
